{
  "name": "react-priority-overflow-row",
  "version": "0.1.0",
  "description": "A measured React row layout primitive that coordinates responsive child variants by priority before wrapping groups.",
  "type": "module",
  "license": "MIT",
  "author": "Kaï Bergmann",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiizen/react-priority-overflow-row.git"
  },
  "homepage": "https://github.com/kaiizen/react-priority-overflow-row#readme",
  "bugs": {
    "url": "https://github.com/kaiizen/react-priority-overflow-row/issues"
  },
  "keywords": [
    "react",
    "responsive",
    "overflow",
    "priority",
    "toolbar",
    "adaptive-layout"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "vite examples/basic --host 127.0.0.1",
    "docs:gifs": "node scripts/generate-gifs.mjs",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0"
  },
  "dependencies": {
    "react-use-measure": "^2.1.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "gifenc": "^1.0.3",
    "jsdom": "^27.1.0",
    "sharp": "^0.34.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.8"
  }
}
